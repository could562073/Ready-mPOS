# Copy this file to docker/.env and adjust values for your local setup
# docker/.env is git-ignored — never commit real credentials

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/readympos
DB_USER=readympos
DB_PASS=readympos

# pgAdmin (開發用資料庫管理介面)
PGADMIN_EMAIL=admin@readympos.local
PGADMIN_PASSWORD=admin
